# ============================================================
# GQR Workspace .gitignore
# Updated: 2026-03-24
# Strategy: Track infrastructure (config, skills, tools, .md,
# .py, .json). Exclude business documents and binaries.
# ============================================================

# --- Node / package artifacts ---
node_modules/
package.json
package-lock.json
Dockerfile

# --- OS / editor junk ---
desktop.ini
.849C9593-D756-4E56-8D6E-42412F2A707B
*.lnk
Thumbs.db
.DS_Store

# --- Credentials ---
.env
**/.env
*.env.*

# --- Claude internal ---
.claude/plans/
.claude/Apartment Documents/
.claude/Biotech News/
.claude/CVs/
.claude/Downloads - Copy/
.claude/In Basket/

# --- Business documents (binary formats) ---
*.docx
*.docm
*.xlsx
*.xls
*.pptx
*.pdf
*.odt
*.doc
*.csv

# --- Database files ---
*.db
*.sqlite
*.sqlite3

# --- Python artifacts ---
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# --- Large binary files ---
SigmaOS.dmg
*.msi
*.zip
*.mp4
*.dmg
*.exe

