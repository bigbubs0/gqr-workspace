# GQR Workspace Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# --- Anthropic (Claude Code CLI, autoresearch evals) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI (recruiter-tool candidate extraction) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium

# --- Telemetry (recruiter-tool) ---
TELEMETRY_ENABLED=true
TELEMETRY_DIR=telemetry
TELEMETRY_LOG_RAW_PROMPTS=false

# --- Notion & Make.com ---
# Auth managed through MCP plugin settings, not env vars.
# Re-authenticate via plugin settings if tokens expire.
