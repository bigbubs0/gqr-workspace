├── GQR Vault\                       # Obsidian vault — separate intake, untouched
│   └── 00_Inbox\                    # Obsidian-only intake (kept)
├── Dev Projects\                    # untouched
├── Pictures\ Documents\ Desktop\    # Windows known folders, untouched
